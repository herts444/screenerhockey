{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vue",
  "installCommand": "echo 'skip npm install'",
  "rewrites": [
    { "source": "/api/auth/register", "destination": "/api/auth?action=register" },
    { "source": "/api/auth/login", "destination": "/api/auth?action=login" },
    { "source": "/api/auth/me", "destination": "/api/auth?action=me" },
    { "source": "/api/admin/users", "destination": "/api/admin-users" },
    { "source": "/api/lineups/matches", "destination": "/api/lineups-matches" },
    { "source": "/api/lineups/lineup", "destination": "/api/lineups-lineup" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/register", "destination": "/index.html" },
    { "source": "/no-access", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/value-bets", "destination": "/index.html" },
    { "source": "/lineups", "destination": "/index.html" },
    { "source": "/winners", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ],
  "functions": {
    "api/**/*.py": {
      "maxDuration": 30,
      "includeFiles": "api/auth_helpers.py"
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-api-sports",
      "schedule": "0 10 * * *"
    }
  ]
}
